{
  "name": "mcqueen",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "css:types": "tcm -p 'src/**/*.module.css' src",
    "css:types:check": "tcm -p 'src/**/*.module.css' src --listDifferent",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "cy:open": "cypress open",
    "cy:exec": "cypress run --config baseUrl=http://localhost:4173",
    "cy:run": "vite build && start-server-and-test preview http://localhost:4173 cy:exec",
    "cy:run:parallel": "vite build && start-server-and-test preview http://localhost:4173 'cypress-parallel -s cy:exec -t 3 -d cypress/e2e'",
    "cy:coverage": "CYPRESS_COVERAGE=true vite build && CYPRESS_COVERAGE=true start-server-and-test 'vite preview' http://localhost:4173 cy:exec",
    "cy:check-coverage": "nyc check-coverage",
    "tracker": "bash -c 'source ~/.nvm/nvm.sh && nvm exec 22 bdui start --open'"
  },
  "dependencies": {
    "beads-ui": "^0.9.3",
    "framer-motion": "^12.23.25",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.3",
    "react-router-dom": "^7.10.1",
    "recharts": "^3.5.1"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^3.14.7",
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "cypress": "^15.10.0",
    "cypress-parallel": "^0.14.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^16.5.0",
    "happy-dom": "^20.6.2",
    "prettier": "^3.8.1",
    "start-server-and-test": "^2.1.3",
    "typed-css-modules": "^0.9.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.4.18",
    "vite-plugin-istanbul": "^7.2.1",
    "vitest": "^4.0.18"
  }
}
