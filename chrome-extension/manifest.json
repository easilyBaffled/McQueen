{
  "manifest_version": 3,
  "name": "McQueen Fantasy Stock Market",
  "description": "Shows stock market indicators for fantasy football players on ESPN.com",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.espn.com/*"],
      "js": ["playerData.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [],
  "host_permissions": ["*://*.espn.com/*"]
}
